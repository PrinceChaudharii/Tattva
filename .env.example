# ╔══════════════════════════════════════════════════════════════╗
# ║  Tattva — Environment Variables                             ║
# ║  Copy this file to .env.local and fill in the values        ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Core ──────────────────────────────────────────────────────
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────
# PostgreSQL connection string (required)
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://tattva:tattva@localhost:5432/tattva

# ── Authentication (NextAuth.js) ──────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Public URL of the site (required in production)
NEXTAUTH_URL=http://localhost:3000

# ── Search (future) ──────────────────────────────────────────
# Typesense / Meilisearch / Algolia credentials
# SEARCH_API_KEY=
# SEARCH_HOST=

# ── Analytics (future) ───────────────────────────────────────
# PostHog / Plausible / Umami
# NEXT_PUBLIC_ANALYTICS_ID=

# ── File Storage (future) ────────────────────────────────────
# S3-compatible storage for media assets
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=

# ── Email (future) ───────────────────────────────────────────
# SMTP / Resend / SendGrid for transactional emails
# EMAIL_FROM=
# EMAIL_SERVER=

# ── CMS / Content (future) ───────────────────────────────────
# Content management / headless CMS integration
# CMS_API_URL=
# CMS_API_KEY=
