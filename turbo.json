{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "NEXTAUTH_SECRET",
    "NEXTAUTH_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "persistent": true,
      "cache": false,
      "interactive": true
    },
    "lint": {
      "dependsOn": ["^typecheck"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "format": {
      "dependsOn": []
    },
    "clean": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:generate": {
      "outputs": ["drizzle/**"]
    },
    "db:migrate": {
      "cache": false,
      "dependsOn": ["db:generate"]
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "content:build": {
      "dependsOn": ["^build"],
      "outputs": ["content/**", ".contentlayer/**"]
    },
    "content:validate": {
      "cache": false
    }
  }
}
